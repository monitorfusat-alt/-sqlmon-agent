{
  "__inputs": [
    {
      "name": "DS_GRAFANACLOUD",
      "label": "Grafana Cloud Prometheus",
      "description": "Datasource OTLP/Prometheus de Grafana Cloud",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",    "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel",      "id": "stat",       "name": "Stat",       "version": "" },
    { "type": "panel",      "id": "table",      "name": "Table",      "version": "" },
    { "type": "panel",      "id": "timeseries", "name": "Time series","version": "" },
    { "type": "panel",      "id": "bargauge",   "name": "Bar gauge",  "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "dashboard",
      "includeVars": true,
      "keepTime": true,
      "tags": ["sqlmon"],
      "targetBlank": false,
      "title": "→ Detalle Servidor",
      "tooltip": "",
      "type": "dashboards",
      "url": ""
    }
  ],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Estado de la Granja",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "mappings": [],
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Servidores CRÍTICOS",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
          "expr": "count(sqlmon_all_metrics{metric_name=\"sql_cpu_percent\", job=\"sqlmon-agent\"} > 80) or vector(0)",
          "legendFormat": "Críticos CPU >80%",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 5 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Queries Lentas Activas (>10s)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
          "expr": "count(sqlmon_all_metrics{metric_name=\"sql_slow_query_elapsed_sec\", job=\"sqlmon-agent\"} > 10) or vector(0)",
          "legendFormat": "Slow queries",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 24 },
              { "color": "red",    "value": 48 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Backups Vencidos (FULL >24h)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
          "expr": "count(sqlmon_all_metrics{metric_name=\"sql_hours_since_full_backup\", job=\"sqlmon-agent\"} > 24) or vector(0)",
          "legendFormat": "Backups vencidos",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 3 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Jobs Fallidos",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
          "expr": "count(sqlmon_all_metrics{metric_name=\"sql_job_last_run_status\", job=\"sqlmon-agent\"} == 0) or vector(0)",
          "legendFormat": "Jobs fallidos",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 3 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Deadlocks (última hora)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
          "expr": "sum(sqlmon_all_metrics{metric_name=\"sql_deadlocks_last_hour\", job=\"sqlmon-agent\"}) or vector(0)",
          "legendFormat": "Deadlocks",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red",    "value": 5 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 7,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Bloqueos Críticos (>30s)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
          "expr": "sum(sqlmon_all_metrics{metric_name=\"sql_critical_blocks\", job=\"sqlmon-agent\"}) or vector(0)",
          "legendFormat": "Bloqueos críticos",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "CPU por Servidor — Últimas 3h",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red",    "value": 85 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "id": 11,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull","max","mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "sql_cpu_percent — Todos los servidores",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
          "expr": "sqlmon_all_metrics{metric_name=\"sql_cpu_percent\", job=\"sqlmon-agent\"}",
          "legendFormat": "{{server}}",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 20,
      "title": "Tabla de Instancias — Estado Actual",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red",    "value": 85 }
            ]
          },
          "mappings": [],
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "cpu" },
            "properties": [
              { "id": "displayName", "value": "CPU %" },
              { "id": "unit", "value": "percent" },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 70 },
                { "color": "red", "value": 85 }
              ]}}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "mem" },
            "properties": [
              { "id": "displayName", "value": "Mem Commit GB" },
              { "id": "unit", "value": "decgbytes" },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 48 },
                { "color": "red", "value": 56 }
              ]}}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "conn" },
            "properties": [
              { "id": "displayName", "value": "Conexiones" },
              { "id": "unit", "value": "short" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "blocked" },
            "properties": [
              { "id": "displayName", "value": "Bloqueadas" },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 1 },
                { "color": "red", "value": 5 }
              ]}}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "slow_q" },
            "properties": [
              { "id": "displayName", "value": "Slow Queries" },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 1 },
                { "color": "red", "value": 5 }
              ]}}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "backup_full_h" },
            "properties": [
              { "id": "displayName", "value": "Full Backup (h)" },
              { "id": "unit", "value": "h" },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 24 },
                { "color": "red", "value": 48 }
              ]}}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Server" },
            "properties": [
              { "id": "custom.width", "value": 160 },
              { "id": "links", "value": [
                {
                  "title": "Ver detalle",
                  "url": "/d/sqlmon-detail/sqlmon-detalle-servidor?var-server=${__data.fields.Server}&${__url_time_range}"
                }
              ]}
            ]
          }
        ]
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 15 },
      "id": 21,
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "CPU %" }]
      },
      "title": "Instancias — Estado actual (última lectura)",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
          "expr": "sqlmon_all_metrics{metric_name=\"sql_cpu_percent\", job=\"sqlmon-agent\"}",
          "legendFormat": "",
          "instant": true,
          "refId": "CPU",
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
          "expr": "sqlmon_all_metrics{metric_name=\"sql_committed_memory_gb\", job=\"sqlmon-agent\"}",
          "legendFormat": "",
          "instant": true,
          "refId": "MEM",
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
          "expr": "sqlmon_all_metrics{metric_name=\"sql_user_connections\", job=\"sqlmon-agent\"}",
          "legendFormat": "",
          "instant": true,
          "refId": "CONN",
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
          "expr": "count by (server, entorno, grupo, region) (sqlmon_all_metrics{metric_name=\"sql_slow_query_elapsed_sec\", job=\"sqlmon-agent\"} > 10)",
          "legendFormat": "",
          "instant": true,
          "refId": "SLOW",
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
          "expr": "sqlmon_all_metrics{metric_name=\"sql_blocked_sessions\", job=\"sqlmon-agent\"}",
          "legendFormat": "",
          "instant": true,
          "refId": "BLOCK",
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
          "expr": "max by (server) (sqlmon_all_metrics{metric_name=\"sql_hours_since_full_backup\", job=\"sqlmon-agent\"})",
          "legendFormat": "",
          "instant": true,
          "refId": "BKUP",
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "server": "Server",
              "entorno": "Entorno",
              "grupo": "Grupo",
              "Value #CPU": "cpu",
              "Value #MEM": "mem",
              "Value #CONN": "conn",
              "Value #SLOW": "slow_q",
              "Value #BLOCK": "blocked",
              "Value #BKUP": "backup_full_h"
            },
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "ip": false,
              "job": true,
              "metric_name": true,
              "prioridad": true,
              "region": false,
              "instance": true
            }
          }
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 30,
      "title": "Queries Lentas — Todos los Servidores",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red",    "value": 300 }
            ]
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "server" },
            "properties": [
              { "id": "displayName", "value": "Servidor" },
              { "id": "custom.width", "value": 140 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "database" },
            "properties": [
              { "id": "displayName", "value": "Base de Datos" },
              { "id": "custom.width", "value": 140 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "severity" },
            "properties": [
              { "id": "displayName", "value": "Severidad" },
              { "id": "custom.width", "value": 100 },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null }
              ]}},
              { "id": "mappings", "value": [
                { "type": "value", "options": { "CRITICAL": { "color": "red",    "text": "CRITICAL", "index": 0 } } },
                { "type": "value", "options": { "WARNING":  { "color": "yellow", "text": "WARNING",  "index": 1 } } },
                { "type": "value", "options": { "ELEVATED": { "color": "blue",   "text": "ELEVATED", "index": 2 } } }
              ]}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Duración (s)" },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "id": 31,
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Duración (s)" }]
      },
      "title": "sql_slow_query_elapsed_sec — Queries activas >10s",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
          "expr": "sqlmon_all_metrics{metric_name=\"sql_slow_query_elapsed_sec\", job=\"sqlmon-agent\"} > 10",
          "legendFormat": "",
          "instant": true,
          "refId": "A",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "server": "server",
              "database": "database",
              "severity": "severity",
              "session_id": "session_id",
              "entorno": "entorno"
            },
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "ip": true,
              "grupo": true,
              "region": true,
              "prioridad": true,
              "instance": true,
              "metric_name": true
            }
          }
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "id": 40,
      "title": "Backups — Estado por Servidor",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 24 },
              { "color": "red",    "value": 48 }
            ]
          },
          "unit": "h",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 39 },
      "id": 41,
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "text": {}
      },
      "title": "sql_hours_since_full_backup — por servidor/base",
      "type": "bargauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
          "expr": "sqlmon_all_metrics{metric_name=\"sql_hours_since_full_backup\", job=\"sqlmon-agent\"}",
          "legendFormat": "{{server}} / {{database}}",
          "instant": true,
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_GRAFANACLOUD}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
